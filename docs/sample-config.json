{
  "steam": {
    "appId": null
  },
  "game": {
    "name": "Your Game Name",
    "searchTerms": [
      "co-op horror",
      "physics sandbox",
      "indie horror"
    ],
    "similarGames": [
      "Lethal Company",
      "Content Warning"
    ],
    "excludeTerms": [
      "mobile game",
      "casino"
    ]
  },
  "youtube": {
    "apiKeyEnvironmentVariable": "YOUTUBE_API_KEY",
    "maxQueries": 6,
    "resultsPerQuery": 15,
    "restrictToGamingCategory": true,
    "markets": [
      {
        "name": "English",
        "relevanceLanguage": "en",
        "regionCode": "US",
        "queryTerms": [ "gameplay", "review", "let's play", "demo", "preview" ]
      },
      {
        "name": "French",
        "relevanceLanguage": "fr",
        "regionCode": "FR",
        "queryTerms": [ "gameplay", "test", "avis", "découverte", "aperçu" ]
      },
      {
        "name": "Chinese",
        "relevanceLanguage": "zh-CN",
        "regionCode": "TW",
        "queryTerms": [ "实况", "评测", "试玩", "游戏演示" ]
      },
      {
        "name": "Japanese",
        "relevanceLanguage": "ja",
        "regionCode": "JP",
        "queryTerms": [ "実況", "レビュー", "プレイ動画", "紹介" ]
      },
      {
        "name": "Brazilian Portuguese",
        "relevanceLanguage": "pt-BR",
        "regionCode": "BR",
        "queryTerms": [ "gameplay", "analise", "análise", "detonado", "review" ]
      },
      {
        "name": "German",
        "relevanceLanguage": "de",
        "regionCode": "DE",
        "queryTerms": [ "gameplay", "lets play", "let's play", "review", "test" ]
      }
    ],
    "publishedWithinMonths": 24,
    "minSubscribers": 1000,
    "maxSubscribers": 750000
  },
  "scoring": {
    "idealMinSubscribers": 5000,
    "idealMaxSubscribers": 250000,
    "minimumMatchedVideos": 2,
    "requirePublicEmail": false
  },
  "export": {
    "outputDirectory": "output",
    "fileNamePrefix": "youtube-creators",
    "includeTimestampInFileNames": true
  }
}
